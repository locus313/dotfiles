Host github.com
  User git
  Port 22
  PreferredAuthentications publickey
  PubkeyAcceptedKeyTypes +ssh-rsa
  {{- if eq .chezmoi.os "darwin" }}
  {{- if (or (eq .pmode true) (eq .oagmode true)) }}
  # .pub file intentionally used: when authenticating via the Bitwarden SSH agent,
  # specifying the public key tells SSH which key to offer from the agent without
  # requiring the private key on disk. OpenSSH resolves the agent key by public key match.
  IdentityFile ~/.ssh/id_rsa.pub
  IdentityAgent ~/.bitwarden-ssh-agent.sock
  {{- end }}
  {{- if eq .ptxmode true }}
  # .pub file intentionally used: SSH selects the matching key from the 1Password agent.
  IdentityFile ~/.ssh/id_rsa.pub
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  {{- end }}
  {{- end }}
{{- if eq .oagmode true }}
Host github-oag.com
  HostName github.com
  User git
  Port 22
  PreferredAuthentications publickey
  # .pub file intentionally used: SSH selects the matching key from the Bitwarden agent.
  IdentityFile ~/.ssh/ed25519.pub
  {{- if ne .chezmoi.os "windows" }}
  IdentityAgent ~/.bitwarden-ssh-agent.sock
  {{- end }}
Host [0-9]*.[0-9]*.[0-9]*.[0-9]*
  Port 22
  PreferredAuthentications publickey
  # .pub file intentionally used: SSH selects the matching key from the Bitwarden agent.
  IdentityFile ~/.ssh/ed25519.pub
  {{- if ne .chezmoi.os "windows" }}
  IdentityAgent ~/.bitwarden-ssh-agent.sock
  {{- end }}
{{- end }}

{{- if eq .ptxmode true }}
Host i-* mi-*
  User ec2-user
  ProxyCommand bash -c "aws ssm start-session --target %h --document-name AWS-StartSSHSession --parameters 'portNumber=%p'"
{{- end }}