{{- if (or (eq .chezmoi.os "windows") (eq .chezmoi.os "darwin")) -}}
<#
.SYNOPSIS
    Patrick Lewis's PowerShell Profile - Cross-platform dotfiles configuration
.DESCRIPTION
    This profile provides consistent PowerShell configuration across Windows and macOS,
    with mode-based feature enablement and proper error handling.
.NOTES
    Author: Patrick Lewis
    Mode System: pmode (Personal), oagmode (Enterprise), ptxmode (Corporate)
    Optimized for fast loading with lazy initialization
#>

# Set UTF-8 encoding for better compatibility
# https://ohmyposh.dev/docs/faq#my-prompt-is-broken-after-upgrading-to-powershell-74
[Console]::OutputEncoding = [Text.Encoding]::UTF8

# Initialize oh-my-posh with night-owl theme
if (Get-Command oh-my-posh -ErrorAction SilentlyContinue) {
{{- if eq .chezmoi.os "darwin" }}
    $themePath = "$(brew --prefix oh-my-posh)/themes/night-owl.omp.json"
{{- else }}
    $themePath = "$env:POSH_THEMES_PATH\night-owl.omp.json"
{{- end }}
    if (Test-Path $themePath) {
        oh-my-posh init pwsh --config $themePath | Invoke-Expression
    } else {
        oh-my-posh init pwsh | Invoke-Expression
    }
}

# Function to lazy-load modules on first use
function Import-ModuleLazy {
    param(
        [string]$ModuleName,
        [string]$Description
    )
    
    if (-not (Get-Module -ListAvailable -Name $ModuleName -ErrorAction SilentlyContinue)) {
        Write-Host "Installing $ModuleName..." -ForegroundColor Yellow
        Install-Module -Name $ModuleName -Scope CurrentUser -Force -SkipPublisherCheck -AllowClobber -ErrorAction SilentlyContinue
    }
    Import-Module -Name $ModuleName -ErrorAction SilentlyContinue
}

# Import only essential modules immediately (PSReadLine for better UX)
Import-ModuleLazy -ModuleName "PsReadLine" -Description "Enhanced command line editing"

# Lazy-load posh-git on first git command
$global:__poshGitLoaded = $false
function Enable-PoshGit {
    if (-not $global:__poshGitLoaded) {
        Import-ModuleLazy -ModuleName "posh-git" -Description "Git integration"
        $global:__poshGitLoaded = $true
    }
}

# Lazy-load Terminal-Icons on first directory listing
$global:__terminalIconsLoaded = $false
function Enable-TerminalIcons {
    if (-not $global:__terminalIconsLoaded) {
        Import-ModuleLazy -ModuleName "Terminal-Icons" -Description "File icons"
        $global:__terminalIconsLoaded = $true
    }
}

# Defer Azure CLI tab completion registration (only register if az command is used)
$global:__azCompletionRegistered = $false
function Register-AzCompletion {
    if (-not $global:__azCompletionRegistered -and (Get-Command az -ErrorAction SilentlyContinue)) {
        Register-ArgumentCompleter -Native -CommandName az -ScriptBlock {
            param($commandName, $wordToComplete, $cursorPosition)
            
            $completion_file = New-TemporaryFile
            $env:ARGCOMPLETE_USE_TEMPFILES = 1
            $env:_ARGCOMPLETE_STDOUT_FILENAME = $completion_file
            $env:COMP_LINE = $wordToComplete
            $env:COMP_POINT = $cursorPosition
            $env:_ARGCOMPLETE = 1
            $env:_ARGCOMPLETE_SUPPRESS_SPACE = 0
            $env:_ARGCOMPLETE_IFS = "`n"
            $env:_ARGCOMPLETE_SHELL = 'powershell'
            
            az 2>&1 | Out-Null
            
            $completions = Get-Content $completion_file | Sort-Object | ForEach-Object {
                [System.Management.Automation.CompletionResult]::new($_, $_, "ParameterValue", $_)
            }
            
            Remove-Item $completion_file, Env:\_ARGCOMPLETE_STDOUT_FILENAME, Env:\ARGCOMPLETE_USE_TEMPFILES, Env:\COMP_LINE, Env:\COMP_POINT, Env:\_ARGCOMPLETE, Env:\_ARGCOMPLETE_SUPPRESS_SPACE, Env:\_ARGCOMPLETE_IFS, Env:\_ARGCOMPLETE_SHELL -ErrorAction SilentlyContinue
            
            return $completions
        }
        $global:__azCompletionRegistered = $true
    }
}

# Load PowerShell script modules
{{- if eq .chezmoi.os "darwin" }}
$scriptPath = "$env:HOME/Scripts/PowerShell"
{{- else }}
$scriptPath = "$env:USERPROFILE/Scripts/PowerShell"
{{- end }}

# Core scripts to load immediately
$coreScripts = @("psreadline.ps1", "chezmoi.ps1", "githelpers.ps1", "linuxlike.ps1", "utils.ps1")

{{- if eq .pmode true }}
# Add mode-specific scripts
$coreScripts += "rename.ps1"
{{- end }}

# Load scripts with minimal error handling overhead
foreach ($scriptName in $coreScripts) {
    $fullPath = Join-Path $scriptPath $scriptName
    if (Test-Path $fullPath) {
        . $fullPath
    }
}

# Load additional helper scripts for Enterprise mode
{{- if eq .oagmode true }}
{{- if eq .chezmoi.os "darwin" }}
$helperScriptPath = "$env:HOME/code/helper-scripts/powershell/Microsoft.PowerShell_profile.ps1"
{{- else }}
$helperScriptPath = "$env:USERPROFILE\code\helper-scripts\powershell\Microsoft.PowerShell_profile.ps1"
{{- end }}

if (Test-Path $helperScriptPath) {
    . $helperScriptPath
}
{{- end }}

# Configure environment variables
$env:XDG_CONFIG_HOME = "$env:USERPROFILE\.config"

